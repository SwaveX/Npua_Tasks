<Window x:Class="Unions.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Unions"
        mc:Ignorable="d"
        Title="Unions" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <ComboBox x:Name="leftSet" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="Set_SelectionChanged"/>
        <ComboBox x:Name="operation" HorizontalAlignment="Left" Margin="160,10,0,0" VerticalAlignment="Top" Width="120"/>
        <ComboBox x:Name="rightSet" HorizontalAlignment="Left" Margin="310,10,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="Set_SelectionChanged"/>

        <Button x:Name="evaluateButton" Content="Evaluate" HorizontalAlignment="Left" Margin="460,10,0,0" VerticalAlignment="Top" Width="75" Click="EvaluateButton_Click"/>

        <ListBox x:Name="leftMembers" HorizontalAlignment="Left" Height="217" Margin="10,64,0,0" VerticalAlignment="Top" Width="120"/>
        <ListBox x:Name="rightMembers" HorizontalAlignment="Left" Height="217" Margin="310,64,0,0" VerticalAlignment="Top" Width="120"/>
        <ListBox x:Name="resultSet" HorizontalAlignment="Left" Height="217" Margin="460,64,0,0" VerticalAlignment="Top" Width="120"/>
    </Grid>
</Window>
